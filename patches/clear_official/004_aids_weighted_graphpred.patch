+
+def _label_scalar(value):
+    arr = np.asarray(value).reshape(-1)
+    return int(arr[0])
+
+
+def _count_dict(values):
+    counter = Counter(int(v) for v in values)
+    return {str(label): int(counter.get(label, 0)) for label in sorted({0, 1, *counter.keys()})}
+
+
+def compute_class_weights_from_split(data, idx_train, num_class, dataset):
+    if dataset != 'aids':
+        return None
+    labels = [_label_scalar(data.labels_all[int(index)]) for index in idx_train]
+    counts = Counter(labels)
+    total = float(len(labels))
+    weights = []
+    for class_id in range(int(num_class)):
+        count = float(counts.get(class_id, 0))
+        if count <= 0:
+            weights.append(0.0)
+        else:
+            weights.append(total / (float(num_class) * count))
+    class_weights = torch.tensor(weights, dtype=torch.float32).to(device)
+    print('[CLEAR_AIDS_CLASS_BALANCE]')
+    print('train_label_counts=', _count_dict(labels))
+    print('class_weights=', [float(value) for value in class_weights.detach().cpu().numpy().tolist()])
+    return class_weights
+
+
+def _safe_float(value):
+    if value is None:
+        return float('nan')
+    if isinstance(value, torch.Tensor):
+        return float(value.detach().cpu().item())
+    return float(value)
+
+
+def _format_float(value):
+    number = _safe_float(value)
+    if math.isnan(number):
+        return 'nan'
+    return f'{number:.4f}'
+
+
+def _checkpoint_is_better(value, best_value, checkpoint_metric):
+    number = _safe_float(value)
+    if math.isnan(number):
+        return False
+    if checkpoint_metric == 'loss':
+        return number < best_value
+    return number > best_value
+
+
