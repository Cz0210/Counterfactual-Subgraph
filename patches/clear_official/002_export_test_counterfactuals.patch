+def clear_wrapper_to_numpy(value):
+    if torch.is_tensor(value):
+        return value.detach().cpu().numpy()
+    if isinstance(value, np.ndarray):
+        return value
+    return np.asarray(value)
+
+
+def clear_wrapper_to_list(value):
+    return clear_wrapper_to_numpy(value).tolist()
+
+
+def clear_wrapper_scalar(value):
+    arr = clear_wrapper_to_numpy(value).reshape(-1)
+    if len(arr) == 0:
+        return None
+    item = arr[0]
+    if isinstance(item, np.generic):
+        item = item.item()
+    return item
+
+
+def clear_wrapper_int(value):
+    item = clear_wrapper_scalar(value)
+    if item is None:
+        return None
+    return int(item)
+
+
+def clear_wrapper_float(value):
+    item = clear_wrapper_scalar(value)
+    if item is None:
+        return None
+    return float(item)
+
+
+def clear_wrapper_metric_dict(eval_results):
+    result = {}
+    for key, value in eval_results.items():
+        if torch.is_tensor(value):
+            if value.numel() == 1:
+                result[key] = float(value.detach().cpu().item())
+            else:
+                result[key] = value.detach().cpu().numpy().tolist()
+        elif isinstance(value, np.ndarray):
+            result[key] = value.tolist()
+        elif isinstance(value, np.generic):
+            result[key] = value.item()
+        else:
+            result[key] = value
+    return result
+
+
